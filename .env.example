# Docker SQL Server administrator
MSSQL_SA_PASSWORD=<set-a-strong-admin-password>

# Target database read-only application account
TARGET_DB_HOST=127.0.0.1
TARGET_DB_PORT=14330
TARGET_DB_NAME=AdventureWorks2022
TARGET_DB_USER=data_agent_ro
TARGET_DB_PASSWORD=<set-a-strong-password>
TARGET_DB_DRIVER=ODBC Driver 18 for SQL Server
TARGET_DB_ENCRYPT=yes
TARGET_DB_TRUST_SERVER_CERTIFICATE=yes

# MVP single configured LLM Provider (docs/mvp/scope.md). The application must fail
# closed if a required setting below is missing, blank, or invalid.
LLM_PROVIDER=<provider-name>
LLM_MODEL=<model-name>
LLM_API_KEY=<set-your-llm-api-key>
# LLM_BASE_URL is optional depending on LLM_PROVIDER (for example, required for a
# self-hosted or organization-approved private endpoint; not required for some
# hosted providers that resolve the endpoint from LLM_PROVIDER alone).
LLM_BASE_URL=<optional-provider-endpoint>
