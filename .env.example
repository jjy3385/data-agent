# Docker SQL Server administrator
MSSQL_SA_PASSWORD=<set-a-strong-admin-password>

# Target database read-only application account
TARGET_DB_HOST=127.0.0.1
TARGET_DB_PORT=14330
TARGET_DB_NAME=AdventureWorks2022
TARGET_DB_USER=data_agent_ro
TARGET_DB_PASSWORD=<set-a-strong-password>
TARGET_DB_DRIVER=ODBC Driver 18 for SQL Server
TARGET_DB_ENCRYPT=yes
TARGET_DB_TRUST_SERVER_CERTIFICATE=yes

# MVP allows only an organization-approved private LLM endpoint.
# The application must fail closed for public mode or an unapproved endpoint.
LLM_DEPLOYMENT_MODE=private
LLM_BASE_URL=<approved-private-llm-endpoint>
LLM_MODEL=<private-model-name>
